; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Rio — Copacabana"
config/description="Vertical slice — Copacabana quartier, quête du milho, mini-jeu de beach-volley."
run/main_scene="res://scenes/main/Intro.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

EventBus="*res://scripts/core/EventBus.gd"
GameManager="*res://scripts/core/GameManager.gd"
ReputationSystem="*res://scripts/core/ReputationSystem.gd"
TimeOfDay="*res://scripts/core/TimeOfDay.gd"
QuestManager="*res://scripts/quests/QuestManager.gd"
DialogueBridge="*res://scripts/quests/DialogueBridge.gd"
SaveSystem="*res://scripts/core/SaveSystem.gd"
AudioManager="*res://scripts/audio/AudioManager.gd"
SelfCheck="*res://scripts/tests/SelfCheck.gd"
BuildingManager="*res://scripts/core/BuildingManager.gd"
CampaignManager="*res://scripts/core/CampaignManager.gd"
NPCScheduler="*res://scripts/core/NPCScheduler.gd"
DynamicMissionManager="*res://scripts/core/DynamicMissionManager.gd"
CutsceneRunner="*res://scripts/core/CutsceneRunner.gd"
DistrictManager="*res://scripts/core/DistrictManager.gd"
NarrativeJournal="*res://scripts/core/NarrativeJournal.gd"
RandomEventManager="*res://scripts/core/RandomEventManager.gd"
DebugConsole="*res://scripts/debug/DebugConsole.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

