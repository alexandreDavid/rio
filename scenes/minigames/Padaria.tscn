[node name="Goal" type="Label" parent="UI/Tutorial/Panel/Margin/Layout"]
text = "Sors un maximum de fournées de pão de queijo en 100 secondes. Chaque fournée parfaite = R$ 22 de tip."
autowrap_mode = 3
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)

[node name="Sep1" type="HSeparator" parent="UI/Tutorial/Panel/Margin/Layout"]

[node name="Step1" type="Label" parent="UI/Tutorial/Panel/Margin/Layout"]
text = "1. Assemble la plaque (3 ingrédients)
   Va à Farine, Eau ou Queijo → [E] pour prendre.
   Reviens au plan de travail → [E] pour déposer. Répète × 3."
autowrap_mode = 3
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)

[node name="Step2" type="Label" parent="UI/Tutorial/Panel/Margin/Layout"]
text = "2. Enfourne
   Mains libres au plan de travail → [E] prend la plaque.
   Va au four → [E] enfourne."
autowrap_mode = 3
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)

[node name="Step3" type="Label" parent="UI/Tutorial/Panel/Margin/Layout"]
text = "3. Surveille la cuisson
   Barre verte = parfait (4-8 s, R$ 22). Trop court = cru (R$ 6).
   Trop long = brûlé (R$ 0). De la fumée sort du four = sors-la !"
autowrap_mode = 3
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)

[node name="Step4" type="Label" parent="UI/Tutorial/Panel/Margin/Layout"]
text = "4. Sors et vends
   [E] au four = la plaque arrive directement en main.
   Va au panier de vente → [E] vend. Plaque ratée → poubelle [E]."
autowrap_mode = 3
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)

[node name="Sep2" type="HSeparator" parent="UI/Tutorial/Panel/Margin/Layout"]

[node name="Tips" type="Label" parent="UI/Tutorial/Panel/Margin/Layout"]
text = "Astuces : le label au-dessus de toi indique toujours ce que [E] fait. Les stations qui s'éclairent = action possible.
Contrôles : WASD ou Flèches pour bouger, E pour interagir."
autowrap_mode = 3
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.75, 0.85, 0.95, 1)

[node name="StartButton" type="Button" parent="UI/Tutorial/Panel/Margin/Layout"]
