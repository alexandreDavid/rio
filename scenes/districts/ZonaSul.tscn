[node name="ViewpointArpoador" parent="." instance=ExtResource("3_view")]
position = Vector2(680, 80)
viewpoint_id = "arpoador_pedra"
prompt_first = "Voir le coucher de soleil"
flavor_speaker = "Sobrinho"
flavor_text = "La Pedra do Arpoador. Quand le soleil se couche derrière les Dois Irmãos, la foule applaudit comme à un concert. Tu n'avais jamais vu une côte applaudir le ciel."
money_reward = 90

[node name="ViewpointIpanema" parent="." instance=ExtResource("3_view")]
position = Vector2(0, 60)
viewpoint_id = "ipanema_calcadao"
prompt_first = "Admirer le calçadão"
flavor_speaker = "Sobrinho"
flavor_text = "Le motif d'ondas — noir et blanc, signé Burle Marx. Tu marches dessus comme tout le monde, et soudain tu repenses à 'Garota de Ipanema'. Ça résonne dans tes pas."
money_reward = 80

[node name="ViewpointLeblon" parent="." instance=ExtResource("3_view")]
position = Vector2(-700, 60)
viewpoint_id = "leblon_dois_irmaos"
prompt_first = "Contempler les Dois Irmãos"
flavor_speaker = "Sobrinho"
flavor_text = "Au bout du calçadão, les Dois Irmãos plongent dans la mer. Le quartier devient plus calme, plus chic. Le sable est plus blanc, l'air plus salé. Fim da praia."
money_reward = 70

