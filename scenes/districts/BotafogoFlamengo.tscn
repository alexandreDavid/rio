prompt_first = "Voir l'Aterro"
flavor_speaker = "Sobrinho"
flavor_text = "L'Aterro do Flamengo s'étend, vert et infini, entre les immeubles et la baie. Le Cristo veille au loin sur Corcovado. Niterói scintille en face. Le poumon vert de Rio."
money_reward = 80

[node name="ViewpointBotafogoBay" parent="." instance=ExtResource("3_view")]
position = Vector2(-400, -130)
viewpoint_id = "botafogo_enseada"
prompt_first = "Photographier la baie"
flavor_speaker = "Sobrinho"
flavor_text = "L'enseada de Botafogo, courbée comme un croissant, encadrée par le Cristo et le Pão de Açúcar. C'est la carte postale que tu enverrais à ta mère pour la rassurer."
money_reward = 90

[node name="ViewpointUrca" parent="." instance=ExtResource("3_view")]
