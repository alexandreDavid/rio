prompt_first = "Regarder le bondinho"
flavor_speaker = "Sobrinho"
flavor_text = "La station du bondinho. Les cabines bondées montent au pão d'açúcar, redescendent vides. En haut, c'est trois cents mètres au-dessus de la baie. Ici, c'est juste l'odeur des touristes et des hot-dogs."
