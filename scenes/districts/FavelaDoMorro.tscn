[node name="VizinhaSpot" parent="." instance=ExtResource("7_reactive")]
position = Vector2(-180, -150)
npc_id = "vizinha"
prompt = "Parler à la voisine"
variants = [{
"id": "act3_intel",
"flag": "act3_intel_accepted",
"not_flag": "vizinha_intel_done",
"set_flag_after": "vizinha_intel_done",
"actions": {"finish_quest": {"quest": "act3_policia_intel", "objective": "intel_vizinha", "payout": 0}},
"speaker": "Vizinha",
"text": "*regarde par la fenêtre, parle bas* Ramos t'envoie ? *soupire* Bom. Je vais te dire ce que je vois passer. Trois mecs descendent par l'escalier vers Copa chaque mardi à l'aube — sacs noirs, mêmes baskets blanches. Le quatrième porte une chaîne, c'est lui qui paie le silence. *te serre le bras* Ne dis jamais d'où ça vient.",
"choices": ["Tu peux compter sur moi"]
}, {
"id": "thanked",
"flag": "vizinha_quest_done",
"speaker": "Vizinha",
"text": "*joue de la guitare doucement, Beto endormi sur ses genoux* Sobrinho. Tu fais partie du morro maintenant. Si t'as besoin d'un toit la nuit, frappe ici. La porte est sans clé.",
"choices": ["Obrigada, vizinha"]
}, {
"id": "found",
"flag": "beto_found",
"set_flag_after": "vizinha_quest_done",
"actions": {"finish_quest": {"quest": "beto_lost", "objective": "tell_vizinha", "payout": 80}, "rep": {0: 3}},
"speaker": "Vizinha",
"text": "*Beto se jette dans ses bras, elle l'écrase contre sa poitrine, sanglote* Beto, meu bem... *te tend trois billets froissés, sans lever la tête* C'est tout ce que j'ai mis de côté. Prends. Prends, sobrinho. Tu m'as rendu ma vie.",
"choices": ["Obrigado, vizinha"]
}, {
"id": "in_progress",
"flag": "vizinha_quest_taken",
"speaker": "Vizinha",
"text": "*tord son tablier* T'as trouvé Beto, sobrinho ? Il aime traîner près des vendeurs de cocos sur le calçadão... il oublie l'heure, il oublie la maison, il oublie sa mère.",
"choices": ["Je continue de chercher"]
}, {
"id": "default",
"set_flag_after": "vizinha_quest_taken",
"actions": {"accept_quest": "beto_lost"},
"speaker": "Vizinha",
"text": "*t'attrape le bras, paniquée, voix tremblante* Sobrinho ! Tu redescends à Copa ? Mon fils Beto, neuf ans, il est parti ce matin sans dire où. *montre l'escalier* Il porte un t-shirt jaune, des sandalias bleues. *baisse la voix* Si la PM le ramasse... s'il te plaît. Trouve-le-moi.",
"choices": ["Je le cherche"]
}]
