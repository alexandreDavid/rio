[resource]
script = ExtResource("1_quest")
id = "ronaldo_dj_paoacucar"
display_name = "DJ no pôr do sol"
description = "Le DJ habituel du mirante au coucher de soleil est tombé malade. Ronaldo te file le tuyau : monte au sommet et fais le set. Le bondinho prend du monde, les pourboires pleuvent quand le soleil tombe sur la baie."
journal_text = "Monter au Pão de Açúcar et remplacer le DJ malade."
giver_npc_id = "musicien"
ink_knot = "ronaldo_dj_offer"
objectives = Array[Resource]([SubResource("obj_set")])
