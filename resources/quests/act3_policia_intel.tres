[resource]
script = ExtResource("1_quest")
id = "act3_policia_intel"
display_name = "Le carnet du Capitão"
description = "Avant l'opération, Ramos veut un dossier solide. Récupère deux infos sur le réseau du Morro auprès des voisins, puis reviens lui faire ton rapport."
journal_text = "Voisine du Morro → tio Zé → Ramos."
giver_npc_id = "ramos"
ink_knot = "ramos_act3_intel_offer"
objectives = Array[Resource]([SubResource("obj_intel_vizinha"), SubResource("obj_intel_seu_joao"), SubResource("obj_report_ramos")])
