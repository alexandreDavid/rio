[resource]
script = ExtResource("1_quest")
id = "act2_padre_orfanato"
display_name = "Salvem o Orfanato"
description = "La mairie veut raser l'orfanato Nossa Senhora pour bâtir un parking touristique. Le Padre rassemble une pétition : trois commerçants de poids manquent à l'appel. Trouve-les."
journal_text = "Faire signer la pétition à Carlos, Beatriz et Dona Carmen."
giver_npc_id = "padre"
ink_knot = "padre_act2_offer"
objectives = Array[Resource]([SubResource("obj_carlos"), SubResource("obj_beatriz"), SubResource("obj_carmen")])
