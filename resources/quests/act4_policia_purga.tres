[resource]
script = ExtResource("1_quest")
id = "act4_policia_purga"
display_name = "Purga da Madrugada"
description = "Le Chefe ne dort pas la première semaine. Trois nids restent à boucler — Morro, calçadão, Av. Atlântica. Chaque coup de balai consolide ton autorité."
journal_text = "Frapper les trois points chauds signalés par Ramos."
giver_npc_id = "ramos"
ink_knot = "ramos_act4_purga"
