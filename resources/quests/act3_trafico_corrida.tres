description = "Miguel monte le coup de l'année — un convoi qui passe de Copacabana à Niterói en plein Carnaval. Si tu pilotes, tu hérites du Morro. Le Tráfico aura un nouveau roi."
journal_text = "Mener la corrida de Miguel jusqu'à Niterói."
giver_npc_id = "miguel"
ink_knot = "miguel_act3_offer"
objectives = Array[Resource]([SubResource("obj_corrida")])
