[resource]
script = ExtResource("1_quest")
id = "act3_prefeito_endorsements"
display_name = "Trois signatures"
description = "Le Padre veut une coalition visible avant le scrutin. Trois figures du quartier — Carlos à la Lagoa, le padeiro de la Padaria, et le Padre lui-même — doivent te soutenir publiquement. Sans ça, le candidat civique ne pèse rien."
journal_text = "Carlos (Lagoa), padeiro, Padre."
giver_npc_id = "padre"
ink_knot = "padre_act3_endorse_offer"
objectives = Array[Resource]([SubResource("obj_endorse_carlos"), SubResource("obj_endorse_padeiro"), SubResource("obj_endorse_padre")])
money_reward = 0
reputation_rewards = {0: 5}
required_reputation = {}
required_act = 3
