[resource]
script = ExtResource("1_quest")
id = "act4_trafico_tributo"
display_name = "Coleta do Patrão"
description = "Le Morro a un nouveau Patrão et les commerçants doivent le savoir. Passe chez Carlos, Beatriz, le Chef. Pas de violence — juste un rappel."
journal_text = "Collecter le tribut chez les trois commerces."
giver_npc_id = "miguel"
ink_knot = "miguel_act4_tributo"
objectives = Array[Resource]([SubResource("obj_carlos"), SubResource("obj_beatriz"), SubResource("obj_chef")])
money_reward = 1500
reputation_rewards = {2: 5, 0: -3}
required_reputation = {}
required_act = 4
