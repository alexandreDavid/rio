[sub_resource type="Resource" id="obj_return"]
script = ExtResource("2_obj")
id = "return_bracelet"
description = "Rapporter le bracelet au concierge"
optional = false

[resource]
script = ExtResource("1_quest")
id = "find_bracelet_01"
display_name = "Le bracelet perdu"
description = "Une cliente du Palace a perdu son bracelet. Le concierge offre 30 reais pour le retrouver."
journal_text = "Chercher un bracelet sur le sable"
giver_npc_id = "concierge"
ink_knot = "concierge_offer"
objectives = Array[Resource]([SubResource("obj_find"), SubResource("obj_return")])
money_reward = 0
reputation_rewards = {}
