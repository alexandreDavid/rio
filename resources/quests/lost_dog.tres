optional = false

[resource]
script = ExtResource("1_quest")
id = "lost_dog"
display_name = "Bingo a disparu"
description = "Dona Irene cherche son petit chien Bingo. Il a filé sur la plage en chassant un crabe. Va le retrouver et ramène-le-lui."
journal_text = "Trouver Bingo sur le sable, puis le ramener à Dona Irene."
giver_npc_id = "dona_irene"
ink_knot = "irene_intro"
objectives = Array[Resource]([SubResource("obj_find"), SubResource("obj_return")])
money_reward = 60
reputation_rewards = {0: 2, 4: 1}
required_reputation = {}
required_act = 0
