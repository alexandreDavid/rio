[gd_resource type="Resource" script_class="Quest" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_carlos"]
script = ExtResource("2_obj")
id = "heard_carlos"
description = "Écouter la doléance de Carlos (livraisons à vélo bloquées)"
optional = false

[sub_resource type="Resource" id="obj_beatriz"]
script = ExtResource("2_obj")
id = "heard_beatriz"
description = "Écouter la doléance de Beatriz (taxe municipale abusive)"
optional = false

[sub_resource type="Resource" id="obj_carmen"]
script = ExtResource("2_obj")
id = "heard_carmen"
description = "Écouter la doléance de Dona Carmen (médicaments retenus)"
optional = false

[resource]
script = ExtResource("1_quest")
id = "act4_prefeito_audiencia"
display_name = "Audiência do Coronel"
description = "Le bairro a confiance en toi maintenant. Trois commerçants te demandent une audience publique. Écoute-les — chaque doléance entendue conforte ton règne."
journal_text = "Recevoir Carlos, Beatriz et Dona Carmen en audience."
giver_npc_id = "padre"
ink_knot = "padre_act4_audiencia"
objectives = Array[Resource]([SubResource("obj_carlos"), SubResource("obj_beatriz"), SubResource("obj_carmen")])
money_reward = 1500
reputation_rewards = {0: 5, 4: 2}
required_reputation = {}
required_act = 4
quest_type = 1
prerequisite_quest_ids = Array[String](["act3_prefeito_eleicao"])
