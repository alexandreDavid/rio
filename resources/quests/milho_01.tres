[gd_resource type="Resource" script_class="Quest" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_pickup"]
script = ExtResource("2_obj")
id = "pickup_cart"
description = "Prendre la charrette de Seu João"
optional = false

[sub_resource type="Resource" id="obj_sell"]
script = ExtResource("2_obj")
id = "sell_all"
description = "Écouler tout le stock de milho"
optional = true

[sub_resource type="Resource" id="obj_return"]
script = ExtResource("2_obj")
id = "return_cart"
description = "Rendre la charrette à Seu João"
optional = false

[resource]
script = ExtResource("1_quest")
id = "quest_milho_01"
display_name = "Vendeur sur la plage"
description = "Seu João te prête sa carrocinha. Écoule le stock, évite les flics, ramène la recette."
journal_text = "Aller parler à Seu João (calçadão, Posto 4)"
giver_npc_id = "seu_joao"
ink_knot = "seu_joao_intro"
objectives = Array[Resource]([SubResource("obj_pickup"), SubResource("obj_sell"), SubResource("obj_return")])
money_reward = 0
reputation_rewards = {}
