[gd_resource type="Resource" script_class="Quest" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_session"]
script = ExtResource("2_obj")
id = "win_basket_session"
description = "Gagner une session de basket de rue à l'Aterro do Flamengo"
optional = false

[resource]
script = ExtResource("1_quest")
id = "ronaldo_aterro_basket"
display_name = "Basquete na Aterro"
description = "Sur l'Aterro do Flamengo, les gamins du quartier organisent des duels de basket trois-points face à la baie. Le pot des paris est tenu par Ronaldo lui-même. Score serré, billets carrés."
journal_text = "Aller à l'Aterro do Flamengo, gagner une session sur le terrain de basket."
giver_npc_id = "ronaldo"
ink_knot = "ronaldo_basket_offer"
objectives = Array[Resource]([SubResource("obj_session")])
money_reward = 350
reputation_rewards = {2: 3, 0: 1}
required_reputation = {}
required_act = 0
