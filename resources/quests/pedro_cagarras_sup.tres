[gd_resource type="Resource" script_class="Quest" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_circuit"]
script = ExtResource("2_obj")
id = "round_islands"
description = "Faire le tour des quatre îlots des Cagarras en stand-up paddle"
optional = false

[resource]
script = ExtResource("1_quest")
id = "pedro_cagarras_sup"
display_name = "Volta nas Cagarras"
description = "Seu Pedro a aperçu une botija (jarre coloniale) coincée entre deux rochers à l'archipel des Cagarras. Il propose au joueur d'y aller en stand-up paddle. Faire le tour des quatre îlots, ramener un croquis de la position. La marée est calme aujourd'hui."
journal_text = "Louer un SUP à la borne de Posto 6, pagayer autour des quatre îlots des Cagarras."
giver_npc_id = "pecheur"
ink_knot = "pecheur_cagarras_offer"
objectives = Array[Resource]([SubResource("obj_circuit")])
money_reward = 250
reputation_rewards = {3: 3, 0: 1}
required_reputation = {}
required_act = 0
