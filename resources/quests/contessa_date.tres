[resource]
script = ExtResource("1_quest")
id = "contessa_date"
display_name = "Notte com Contessa"
description = "Le gala s'est terminé sur un sourire. La Contessa Bianchi veut te revoir, en privé. Choisis bien — restaurant, conversation, fin de soirée. Chaque détail compte."
journal_text = "Soirée privée avec la Contessa : restaurant, dîner, coucher de soleil."
giver_npc_id = "contessa"
ink_knot = "contessa_date_offer"
objectives = Array[Resource]([SubResource("obj_date")])
money_reward = 800
reputation_rewards = {3: 3, 4: 5}
required_reputation = {}
required_act = 0
