[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_date"]
script = ExtResource("2_obj")
id = "complete_date"
description = "Vivre la soirée avec la Contessa Bianchi"
