[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_shift"]
script = ExtResource("2_obj")
id = "first_valet_shift"
description = "Boucler un service complet de valet (5 clients ou 90s)"
