[resource]
script = ExtResource("1_quest")
id = "valet_palace"
display_name = "Valet do Copa Palace"
description = "Otávio, chef-valet du Copacabana Palace, cherche du sang neuf. Gare les voitures des clients à leur arrivée et restitue-les vite quand ils sortent. Tips proportionnels à ton service."
journal_text = "Faire un service complet au stand valet du Palace."
giver_npc_id = "otavio"
ink_knot = "otavio_intro"
objectives = Array[Resource]([SubResource("obj_shift")])
money_reward = 0
reputation_rewards = {3: 2, 4: 1}
required_reputation = {}
required_act = 0
