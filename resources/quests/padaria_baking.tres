[resource]
script = ExtResource("1_quest")
id = "padaria_baking"
display_name = "Aprendiz de padeiro"
description = "Seu Tonio te confie le fournil pour la fournée du matin. Assemble les ingrédients sur la plaque, enfourne, sors au bon moment, panier de vente. Le bairro a faim."
journal_text = "Cuire un lot complet à la padaria São Sebastião."
giver_npc_id = "padeiro"
ink_knot = "padaria_baking_offer"
objectives = Array[Resource]([SubResource("obj_first_batch")])
