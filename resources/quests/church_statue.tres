[gd_resource type="Resource" script_class="Quest" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_find"]
script = ExtResource("2_obj")
id = "find_statue"
description = "Retrouver la statue de Nossa Senhora (plage, côté ouest)"
optional = false

[sub_resource type="Resource" id="obj_return"]
script = ExtResource("2_obj")
id = "return_statue"
description = "Rendre la statue au Padre Anselmo"
optional = false

[resource]
script = ExtResource("1_quest")
id = "church_statue"
display_name = "La statue volée"
description = "Des gamins ont volé la statue de Nossa Senhora à l'église. Retrouve-la sur la plage avant la messe du dimanche."
journal_text = "Chercher la statue sur la plage (côté Forte), puis revenir au Padre."
giver_npc_id = "padre"
ink_knot = "padre_intro"
objectives = Array[Resource]([SubResource("obj_find"), SubResource("obj_return")])
money_reward = 80
reputation_rewards = {0: 3}
required_reputation = {}
required_act = 0
