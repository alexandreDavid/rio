[gd_resource type="Resource" script_class="Quest" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_ronaldo"]
script = ExtResource("2_obj")
id = "tell_ronaldo"
description = "Prévenir Ronaldo que la soirée commence à 20h"
optional = false

[resource]
script = ExtResource("1_quest")
id = "ze_invitation"
display_name = "L'invitation de Zé"
description = "Zé a besoin que Ronaldo vienne jouer ce soir au quiosque. Va lui transmettre le message."
journal_text = "Dire à Ronaldo que Zé l'attend à 20h"
giver_npc_id = "ze_bar"
ink_knot = "ze_offer"
objectives = Array[Resource]([SubResource("obj_ronaldo")])
money_reward = 20
reputation_rewards = {0: 2, 2: 2}
