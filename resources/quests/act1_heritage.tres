id = "earn_seed_money"
description = "Réunir R$ 500 (vends du milho, rends service)"
optional = false

[sub_resource type="Resource" id="obj_first_payment"]
script = ExtResource("2_obj")
id = "first_payment"
description = "Verser le premier acompte au consortium"
optional = false

[resource]
script = ExtResource("1_quest")
id = "act1_heritage"
display_name = "L'héritage empoisonné"
description = "Ton oncle Zé a disparu en te laissant sa charrette et sa dette. Paie un premier acompte au consortium avant le Carnaval."
journal_text = "Parler au consortium (Av. Atlântica), puis verser R$ 500 d'acompte."
giver_npc_id = "seu_joao"
ink_knot = "seu_joao_heritage"
objectives = Array[Resource]([SubResource("obj_meet_consortium"), SubResource("obj_earn_seed"), SubResource("obj_first_payment")])
money_reward = 0
reputation_rewards = {}
required_reputation = {}
required_act = 1
quest_type = 1
prerequisite_quest_ids = Array[String]([])
