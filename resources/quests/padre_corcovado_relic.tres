[gd_resource type="Resource" script_class="Quest" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/quests/Quest.gd" id="1_quest"]
[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_bless"]
script = ExtResource("2_obj")
id = "bless_at_corcovado"
description = "Monter au mirante du Cristo et déposer la relique pour la bénir"
optional = false

[sub_resource type="Resource" id="obj_return"]
script = ExtResource("2_obj")
id = "return_relic"
description = "Rapporter la relique bénie au Padre Anselmo"
optional = false

[resource]
script = ExtResource("1_quest")
id = "padre_corcovado_relic"
display_name = "Bênção do Cristo"
description = "Le Padre te confie une relique de Nossa Senhora. Pour qu'elle soit consacrée pour la procession, elle doit être bénie au pied du Cristo Redentor. Le Corcovado se gravit en taxi depuis l'Av. Atlântica."
journal_text = "Bénir la relique au Mirante du Cristo, puis revenir au Padre."
giver_npc_id = "padre"
ink_knot = "padre_corcovado_offer"
objectives = Array[Resource]([SubResource("obj_bless"), SubResource("obj_return")])
money_reward = 200
reputation_rewards = {0: 5, 4: 2}
required_reputation = {}
required_act = 0
