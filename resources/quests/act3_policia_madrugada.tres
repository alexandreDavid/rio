id = "act3_policia_madrugada"
display_name = "Operação Madrugada"
description = "Ramos a obtenu son mandat. Cette nuit, la Polícia Militar tombe sur le réseau du Morro. Si tu y es, tu deviens Chefe de Polícia honoraire — le bairro entier saura à qui il doit la nouvelle paix."
journal_text = "Rejoindre Ramos pour clore l'opération nocturne."
giver_npc_id = "ramos"
ink_knot = "ramos_act3_offer"
objectives = Array[Resource]([SubResource("obj_madrugada")])
