[resource]
script = ExtResource("1_quest")
id = "act4_carnaval_desfile"
display_name = "Reinado no Carnaval"
description = "Le Carnaval bat son plein. Sur l'avenue Marquês de Sapucaí, l'école de samba locale veut mettre en avant le nouveau patrão de Copacabana. Mener le bloc, taper dans le rythme, garder la foule debout — c'est le couronnement public du règne."
journal_text = "Aller au Sambódromo, lancer le défilé et tenir le rythme."
giver_npc_id = "seu_joao"
ink_knot = "seu_joao_carnaval_offer"
objectives = Array[Resource]([SubResource("obj_lead")])
money_reward = 5000
reputation_rewards = {0: 5, 4: 5, 3: 3}
required_reputation = {}
required_act = 4
