[ext_resource type="Script" path="res://scripts/quests/QuestObjective.gd" id="2_obj"]

[sub_resource type="Resource" id="obj_lap"]
script = ExtResource("2_obj")
id = "complete_lap"
description = "Boucler un tour complet de la Lagoa Rodrigo de Freitas"
