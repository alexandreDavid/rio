[resource]
script = ExtResource("1_quest")
id = "carlos_lagoa_volta"
display_name = "Volta na Lagoa"
description = "Carlos te recommande la Lagoa Rodrigo de Freitas pour décompresser entre deux livraisons. Loue un vélo à la borne et boucle un tour. Plus tu pédales vite, plus les touristes pourboirent."
journal_text = "Faire un tour complet de la Lagoa en vélo."
giver_npc_id = "carlos"
ink_knot = "carlos_lagoa_offer"
objectives = Array[Resource]([SubResource("obj_lap")])
money_reward = 0
reputation_rewards = {3: 3, 0: 2}
required_reputation = {}
required_act = 0
